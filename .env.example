# Postgres connection used by Prisma
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/krispy?schema=public"

# Redis connection used by BullMQ for the render queue
REDIS_URL="redis://localhost:6379"

# Symmetric key (32 bytes, base64) used to encrypt user-supplied BYOK
# provider keys (Gemini, ElevenLabs, Claude) at rest. Generate with:
#   openssl rand -base64 32
#
# Note: there is no GEMINI_API_KEY here — chat/script generation is BYOK
# too right now (each user connects their own Gemini key in Settings), not
# a platform-wide key. See src/lib/gemini.ts.
API_KEY_ENCRYPTION_SECRET=""

# Platform-funded Gemini key, billed to us — powers the free trial pool
# (20 generations per new user, see trialGenerationsRemaining on User and
# resolveGeminiKey in src/lib/providers.ts) for users who haven't connected
# their own BYOK Gemini key yet. Keep this on a separate Google Cloud
# project/billing account from any personal key, and set a budget alert.
# Leave empty to disable the trial (users without a BYOK key just get the
# usual "connect a key" error).
PLATFORM_GEMINI_API_KEY=""

# NextAuth
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Where rendered MP4s are written/served from during local dev
RENDER_OUTPUT_DIR="./renders"
