# Postgres connection used by Prisma
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/krispy?schema=public"

# Redis connection used by BullMQ for the render queue
REDIS_URL="redis://localhost:6379"

# Symmetric key (32 bytes, base64) used to encrypt user-supplied BYOK
# provider keys (OpenAI, Gemini, ElevenLabs, Claude) at rest. Generate with:
#   openssl rand -base64 32
#
# Note: there is no OPENAI_API_KEY here — chat/script generation is BYOK
# too right now (each user connects their own OpenAI key in Settings), not
# a platform-wide key. See src/lib/openai.ts.
API_KEY_ENCRYPTION_SECRET=""

# NextAuth
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Where rendered MP4s are written/served from during local dev
RENDER_OUTPUT_DIR="./renders"
