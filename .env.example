# Postgres connection used by Prisma
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/krispy?schema=public"

# Redis connection used by BullMQ for the render queue
REDIS_URL="redis://localhost:6379"

# Symmetric key (32 bytes, base64) used to encrypt user-supplied BYOK
# provider keys (Gemini, ElevenLabs, Claude) at rest. Generate with:
#   openssl rand -base64 32
#
# Note: there is no GEMINI_API_KEY here — chat/script generation is BYOK
# too right now (each user connects their own Gemini key in Settings), not
# a platform-wide key. See src/ai/gemini.ts.
API_KEY_ENCRYPTION_SECRET=""

# Platform-funded Gemini key, billed to us — powers the free trial pool
# (20 generations per new user, see trialGenerationsRemaining on User and
# resolveGeminiKey in src/ai/providers.ts) for users who haven't connected
# their own BYOK Gemini key yet. Keep this on a separate Google Cloud
# project/billing account from any personal key, and set a budget alert.
# Leave empty to disable the trial (users without a BYOK key just get the
# usual "connect a key" error).
PLATFORM_GEMINI_API_KEY=""

# NextAuth
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudflare R2 (S3-compatible) — required in production, since Vercel's
# filesystem is ephemeral and generated images/voiceovers/renders wouldn't
# survive between requests. All four must be set together for R2 to be used;
# see src/backend/assets.ts. Leave all empty for local dev to fall back to
# writing under public/generated instead.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public base URL for the bucket (the r2.dev subdomain, or a custom domain
# if one's connected) — generated asset URLs are built as `${R2_PUBLIC_URL}/<key>`.
R2_PUBLIC_URL=""

# Public base URL of this app. Used by the render worker (src/backend/queue/
# renderWorker.ts) to resolve relative asset URLs — e.g. the fixed music
# catalog served from public/music — into absolute ones, since the worker
# typically runs on a separate host (Railway/Fly) from the Next app.
APP_URL="http://localhost:3000"

# Where rendered MP4s are written to as scratch space before being uploaded
# to R2 (or served directly from here when R2 isn't configured)
RENDER_OUTPUT_DIR="./renders"
