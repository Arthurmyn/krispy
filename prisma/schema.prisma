// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AspectRatio {
  RATIO_9_16
  RATIO_16_9
  RATIO_1_1
}

enum ProjectStatus {
  DRAFT
  SCRIPTING
  REVIEWING_SCENES
  READY_TO_RENDER
  RENDERING
  COMPLETE
}

enum Platform {
  TIKTOK
  YOUTUBE_SHORTS
  INSTAGRAM_REELS
}

// Drives the script-generation stage machine (src/lib/prompts). Each stage
// exposes exactly one tool to the model, so it can't finalize an idea before
// niche + style are locked in, or scenes before the idea is locked in.
// Order: Niche -> Idea -> Style (passport) -> Parameters (duration, language)
// -> Script -> Script review -> Voiceover review (after images are approved).
enum ChatStage {
  NICHE
  STYLE
  IDEA
  // Duration + language, split out of STYLE so they're asked as their own
  // step instead of bundled with the visual style passport.
  PARAMETERS
  SCRIPT
  SCRIPT_REVIEW
  // Fired automatically once every scene's image is approved (see
  // approveScenes in src/app/api/projects/[id]/route.ts) — the assistant
  // proactively posts the full voiceover script for confirmation/edits.
  VOICEOVER_REVIEW
  // Entered on-demand from the Metadata tab (not part of the main linear
  // flow) — proposes titles/description/tags/thumbnail prompts.
  METADATA
}

enum ChatRole {
  USER
  ASSISTANT
}

enum AssetStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum ApiKeyProvider {
  GEMINI
  ELEVENLABS
  // BYOK phase for chat/script generation — see src/lib/anthropic.ts. Once
  // the business buys its own token pool, this can go back to a shared
  // platform key.
  ANTHROPIC
  // No longer offered in Settings — the OpenAI trial swap was reverted back
  // to Gemini for chat. Value stays in the enum (Postgres can't drop enum
  // values without recreating the type) so existing ApiKey rows saved during
  // the trial stay valid; nothing in the app writes or reads it anymore.
  OPENAI
}

enum RenderStatus {
  QUEUED
  RENDERING
  COMPLETE
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  // Null for Google-only accounts — the credentials provider (email+
  // password) is only offered once this is set. scrypt hash, see
  // src/lib/password.ts.
  passwordHash  String?
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  apiKeys  ApiKey[]
  projects Project[]
}

// Auth.js (NextAuth v5) adapter models — database session strategy.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// BYOK: user-supplied provider keys, encrypted at rest. Never used for our
// own Claude calls — only for the user's own Gemini/ElevenLabs generation.
model ApiKey {
  id            String         @id @default(cuid())
  userId        String
  provider      ApiKeyProvider
  encryptedKey  String
  createdAt     DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  category    String
  aspectRatio AspectRatio
  topic       String?
  status      ProjectStatus @default(DRAFT)
  // References an id in the fixed catalog (src/lib/musicLibrary.ts), not a
  // row in this database — there's no per-user music upload.
  musicTrackId String?

  // Project memory for the script-generation prompt (src/lib/prompts) — set
  // once and reused every turn instead of re-inferred from scratch.
  platform       Platform  @default(TIKTOK)
  audience       String?
  tone           String?
  styleBlock     String?
  characters     String?
  durationSeconds Int?
  language        String?
  chatStage       ChatStage @default(NICHE)

  // YouTube-style publish metadata, proposed via the Metadata tab/chat
  // stage — separate from the script/style fields above since these only
  // exist once the video itself is basically done.
  suggestedTitles String[] @default([])
  description     String?
  tags            String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]
  scenes       Scene[]
  renderJobs   RenderJob[]
  thumbnails   Thumbnail[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  projectId String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Scene {
  id       String @id @default(cuid())
  projectId String
  order    Int

  script      String
  imagePrompt String?
  imageUrl    String?
  imageStatus AssetStatus @default(PENDING)

  voiceoverText   String?
  voiceoverUrl    String?
  voiceoverStatus AssetStatus @default(PENDING)

  durationMs Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, order])
}

// Thumbnail candidates for the video, separate from Scene since they aren't
// part of the render timeline — just standalone images proposed alongside
// titles/description/tags in the Metadata stage.
model Thumbnail {
  id     String @id @default(cuid())
  projectId String
  order  Int

  prompt      String
  imageUrl    String?
  imageStatus AssetStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, order])
}

model RenderJob {
  id        String       @id @default(cuid())
  projectId String
  status    RenderStatus @default(QUEUED)
  outputUrl String?
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
